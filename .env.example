# WorkplaceAIEnv++ Environment Configuration
# Copy this file to .env and fill in your actual values

# REQUIRED: Hugging Face API Token (free tier available)
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: Hugging Face Inference API base URL
# Default: https://router.huggingface.co/hf-inference/v1
API_BASE_URL=https://router.huggingface.co/hf-inference/v1

# Optional: Model name to use for inference
# Must be available on Hugging Face Inference API
# Default: meta-llama/Llama-3.1-8B-Instruct
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Optional: Environment server URL (for local development)
# Default: http://localhost:8000
ENV_SERVER_URL=http://localhost:8000

# Optional: Validation mode for Docker/CI environments
# Set to 'true' to skip token validation during container testing
VALIDATION_MODE=false
